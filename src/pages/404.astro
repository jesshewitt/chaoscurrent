---
import BaseLayout from "@/layouts/BaseLayout.astro"
---
<BaseLayout title="Not found :: Chaos Current" description="Page not found.">
    <section class="notfound">
        <p class="label section-label">404</p>
        <h1>Page not found</h1>
        <p>
            The page you're looking for isn't here. Try the
            <a href="/">home page</a> or browse the
            <a href="/all/">full directory</a>.
        </p>
    </section>
</BaseLayout>

<style>
    .notfound {
        max-width: var(--w-list);
        margin: var(--s-5) auto 0;
        padding: 0 var(--s-2);
    }
    .notfound p { max-width: var(--w-read); }
</style>
