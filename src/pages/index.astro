---
import BaseLayout from "@/layouts/BaseLayout.astro"
import CategoryGrid from "@/components/CategoryGrid.astro"
import Entry from "@/components/Entry.astro"
import { getLinks, getRecent, countsByType } from "@/lib/links.js"

const all = await getLinks()
const counts = countsByType(all)
const recent = await getRecent(6)
---
<BaseLayout
    title="Chaos Current"
    description="A directory of chaos magic: books, essays, blogs, podcasts, tools, and more."
>
    <section class="intro">
        <p class="label">Chaos Current</p>
        <h1>A directory of chaos magic.</h1>
        <p class="lede">
            Chaos magic treats belief as a tool. Borrow what works, drop what
            doesn't, and don't sweat the signage. This is a running index of
            books, essays, blogs, podcasts, tools, communities, and archives,
            for people new to it and people already up to their elbows.
        </p>
    </section>

    <CategoryGrid counts={counts} />

    {recent.length > 0 && (
        <section class="recent">
            <h2 class="label">Recently added</h2>
            <div class="recent-list">
                {recent.map((e) => <Entry entry={e} />)}
            </div>
        </section>
    )}
</BaseLayout>

<style>
    .intro {
        max-width: var(--w-read);
        margin: var(--s-5) auto var(--s-4);
        padding: 0 var(--s-2);
    }
    .intro h1 { margin-top: 0; }
    .intro .lede { color: var(--ink); font-size: var(--fs-18); }

    .recent {
        max-width: var(--w-list);
        margin: var(--s-6) auto 0;
        padding: 0 var(--s-2);
    }
</style>
