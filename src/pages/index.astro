---
import BaseLayout from "@/layouts/BaseLayout.astro"
import TopicGrid from "@/components/TopicGrid.astro"
import FormatChipRow from "@/components/FormatChipRow.astro"
import Entry from "@/components/Entry.astro"
import { getCollection } from "astro:content"
import { getLinks, getRecent, countsByType, getByTopic } from "@/lib/links.js"
import { FEATURED_TOPICS } from "@/lib/taxonomy.js"

const all = await getLinks()
const counts = countsByType(all)
const recent = await getRecent(6)

const topicCollection = await getCollection("topics")
const topicsBySlug = new Map(topicCollection.map((t) => [t.data.slug, t.data]))

const featuredTopicsWithCounts = await Promise.all(
    FEATURED_TOPICS
        .map((slug) => topicsBySlug.get(slug))
        .filter(Boolean)
        .map(async (t) => ({
            ...t,
            count: (await getByTopic(t.slug)).length
        }))
)
---
<BaseLayout
    title="Chaos Current"
    description="A directory of chaos magic: books, essays, blogs, podcasts, tools, and more."
>
    <section class="intro">
        <p class="label">Chaos Current</p>
        <h1>A directory of chaos magic.</h1>
        <p class="lede">
            Chaos magic is a contemporary magical practice that treats belief
            as a tool and is eclectic in its techniques. This site is a
            curated index of books, essays, blogs, podcasts, videos, tools,
            communities, and archives.
        </p>
        <p class="intro-cta">
            New to chaos magic? There's a <a href="/intro/">short intro</a>.
        </p>
    </section>

    <TopicGrid topics={featuredTopicsWithCounts} />

    <p class="browse-all-topics">
        <a href="/topics/">Browse all topics →</a>
    </p>

    <FormatChipRow counts={counts} />

    {recent.length > 0 && (
        <section class="recent">
            <h2 class="label">Recently added</h2>
            <div class="recent-list">
                {recent.map((e) => <Entry entry={e} />)}
            </div>
        </section>
    )}
</BaseLayout>

<style>
    .intro {
        max-width: var(--w-list);
        margin: var(--s-5) auto var(--s-4);
        padding: 0 var(--s-2);
    }
    .intro h1 { margin-top: 0; max-width: var(--w-read); }
    .intro .lede { color: var(--ink); font-size: var(--fs-18); max-width: var(--w-read); }
    .intro-cta { max-width: var(--w-read); }
    .intro-cta {
        margin-top: var(--s-3);
        font-size: var(--fs-18);
    }
    .intro-cta a {
        color: var(--accent);
        font-weight: 500;
    }
    .intro-cta a:hover { color: var(--accent-bright); }

    .browse-all-topics {
        max-width: var(--w-list);
        margin: var(--s-2) auto 0;
        padding: 0 var(--s-2);
        text-align: right;
        font-size: var(--fs-14);
    }
    .browse-all-topics a {
        color: var(--ink-mute);
    }
    .browse-all-topics a:hover {
        color: var(--accent);
    }

    .recent {
        max-width: var(--w-list);
        margin: var(--s-6) auto 0;
        padding: 0 var(--s-2);
    }
</style>
