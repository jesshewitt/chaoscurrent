---
import BaseLayout from "@/layouts/BaseLayout.astro"
import Toolbar from "@/components/Toolbar.astro"
import Entry from "@/components/Entry.astro"
import { getLinks } from "@/lib/links.js"
import { buildSearchDocuments, FUSE_OPTIONS } from "@/lib/search-index.js"
import { getCollection } from "astro:content"

const entries = await getLinks()
const docs = buildSearchDocuments(entries)
const topicCollection = await getCollection("topics")
const topics = topicCollection.map((t) => t.data)

const searchData = JSON.stringify({ docs, options: FUSE_OPTIONS })
---
<BaseLayout
    title="Everything :: Chaos Current"
    description="Browse every entry in the Chaos Current directory with filtering and search."
>
    <section class="all">
        <p class="label section-label">Chaos Current / Everything</p>
        <h1>Everything</h1>

        <Toolbar topics={topics} />

        <script id="search-data" type="application/json" set:html={searchData}></script>

        <div id="entries">
            {entries.map((e) => (
                <div
                    class="entry-wrap"
                    data-id={e.id}
                    data-type={e.type}
                    data-topics={(e.topics ?? []).join(",")}
                >
                    <Entry entry={e} />
                </div>
            ))}
        </div>

        <div id="empty-state" class="empty-state" hidden>
            <p>No results. Try removing a tag or broadening your search.</p>
            <button type="button" id="empty-clear" class="reset">Clear all filters</button>
        </div>
    </section>

    <script>
        const root = document.querySelector("[data-filter-root]")
        if (root) {
            const searchInput = root.querySelector("#filter-search")
            const clearSearchBtn = root.querySelector("#clear-search")
            const checkboxes = [...root.querySelectorAll("input[type=checkbox][data-axis]")]
            const filterToggle = root.querySelector("#filter-toggle")
            const filterPanel = root.querySelector("#filter-panel")
            const filterBadge = root.querySelector("#filter-badge")
            const countEl = root.querySelector("#result-count")
            const clearBtn = root.querySelector("#clear-filters")
            const wraps = [...document.querySelectorAll(".entry-wrap")]
            const emptyState = document.getElementById("empty-state")
            const emptyClear = document.getElementById("empty-clear")

            const raw = document.getElementById("search-data").textContent
            const { docs } = JSON.parse(raw)
            const searchIndex = docs.map((d) => ({
                id: d.id,
                haystack: [d.title, d.author, d.annotation, (d.topics ?? []).join(" ")]
                    .filter(Boolean)
                    .join(" ")
                    .toLowerCase()
            }))

            const state = {
                q: "",
                types: new Set(),
                topics: new Set()
            }

            function readHash() {
                const hash = location.hash.replace(/^#/, "")
                if (!hash) return
                const params = new URLSearchParams(hash)
                state.q = params.get("q") ?? ""
                state.types = new Set((params.get("type") ?? "").split(",").filter(Boolean))
                state.topics = new Set((params.get("topic") ?? "").split(",").filter(Boolean))
            }

            function writeHash() {
                const params = new URLSearchParams()
                if (state.q) params.set("q", state.q)
                if (state.types.size > 0) params.set("type", [...state.types].join(","))
                if (state.topics.size > 0) params.set("topic", [...state.topics].join(","))
                const hash = params.toString()
                const url = hash ? `#${hash}` : location.pathname
                history.replaceState(null, "", url)
            }

            function applyState() {
                for (const cb of checkboxes) {
                    const axis = cb.dataset.axis
                    const value = cb.dataset.value
                    const set = axis === "type" ? state.types : state.topics
                    cb.checked = set.has(value)
                }
                searchInput.value = state.q

                const totalActive = state.types.size + state.topics.size
                filterBadge.textContent = totalActive > 0 ? totalActive : ""

                let allowed
                const q = state.q.trim().toLowerCase()
                if (q.length > 0) {
                    allowed = new Set(
                        searchIndex
                            .filter((d) => d.haystack.includes(q))
                            .map((d) => d.id)
                    )
                } else {
                    allowed = null
                }

                clearSearchBtn.hidden = state.q.length === 0

                let shown = 0
                for (const w of wraps) {
                    const id = w.dataset.id
                    const type = w.dataset.type
                    const topics = w.dataset.topics.split(",").filter(Boolean)

                    const typeOk =
                        state.types.size === 0 || state.types.has(type)
                    const topicOk =
                        state.topics.size === 0 ||
                        [...state.topics].every((t) => topics.includes(t))
                    const searchOk = allowed === null || allowed.has(id)

                    const visible = typeOk && topicOk && searchOk
                    w.hidden = !visible
                    if (visible) shown++
                }

                const total = wraps.length
                countEl.textContent =
                    shown === total ? `${total} entries` : `${shown} of ${total} entries`
                emptyState.hidden = shown !== 0

                const hasFilters =
                    state.q.length > 0 || state.types.size > 0 || state.topics.size > 0
                clearBtn.hidden = !hasFilters
            }

            for (const cb of checkboxes) {
                cb.addEventListener("change", () => {
                    const axis = cb.dataset.axis
                    const value = cb.dataset.value
                    const set = axis === "type" ? state.types : state.topics
                    if (cb.checked) set.add(value)
                    else set.delete(value)
                    writeHash()
                    applyState()
                })
            }

            searchInput.addEventListener("input", () => {
                state.q = searchInput.value
                writeHash()
                applyState()
            })

            clearSearchBtn.addEventListener("click", () => {
                state.q = ""
                searchInput.value = ""
                writeHash()
                applyState()
                searchInput.focus()
            })

            function clearAll() {
                state.q = ""
                state.types.clear()
                state.topics.clear()
                writeHash()
                applyState()
            }

            clearBtn.addEventListener("click", clearAll)
            emptyClear.addEventListener("click", clearAll)

            window.addEventListener("hashchange", () => {
                readHash()
                applyState()
            })

            function isOpen() { return filterPanel.classList.contains("is-open") }
            function openPanel() {
                filterPanel.classList.add("is-open")
                filterToggle.setAttribute("aria-expanded", "true")
            }
            function closePanel() {
                filterPanel.classList.remove("is-open")
                filterToggle.setAttribute("aria-expanded", "false")
            }
            filterToggle.addEventListener("click", (e) => {
                e.stopPropagation()
                if (isOpen()) closePanel()
                else openPanel()
            })
            document.addEventListener("click", (e) => {
                if (!isOpen()) return
                if (filterPanel.contains(e.target)) return
                if (filterToggle.contains(e.target)) return
                closePanel()
            })
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape" && isOpen()) closePanel()
            })

            readHash()
            applyState()

            if (location.hash === "#search") searchInput.focus()
        }
    </script>
</BaseLayout>

<style>
    .all {
        max-width: var(--w-list);
        margin: var(--s-4) auto 0;
        padding: 0 var(--s-2);
    }
    #entries { margin-top: var(--s-3); }

    .empty-state {
        margin: var(--s-4) 0;
        padding: var(--s-3);
        border: 1px dashed var(--rule);
        border-radius: 4px;
        text-align: center;
    }
    .empty-state p { margin: 0 0 var(--s-1); color: var(--ink-mute); }
    .empty-state .reset {
        background: transparent;
        border: 1px solid var(--accent);
        color: var(--accent);
        padding: 6px 14px;
        border-radius: 999px;
        font-family: var(--font-ui);
        font-size: var(--fs-12);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
    }
    .empty-state .reset:hover { color: var(--accent-bright); border-color: var(--accent-bright); }
</style>
