---
import BaseLayout from "@/layouts/BaseLayout.astro"

const curatorEmail = "curator@chaoscurrent.org"
---
<BaseLayout
    title="About :: Chaos Current"
    description="What Chaos Current is, how it is curated, and how to suggest a link."
>
    <article class="about">
        <p class="label section-label">Chaos Current / About</p>
        <h1>About</h1>

        <p>
            Chaos Current is a directory of chaos magic resources: books,
            essays, blogs, podcasts, videos, tools, communities, archives, and
            a few things from the traditions next door.
        </p>

        <h2>Suggest a link</h2>
        <p>
            Send it to
            <a href={`mailto:${curatorEmail}`}>{curatorEmail}</a>
            with the URL, a short description, and why you think it belongs.
        </p>

        <h2>License</h2>
        <p>
            Site code is MIT. Annotations are CC BY 4.0.
        </p>
    </article>
</BaseLayout>

<style>
    .about {
        max-width: var(--w-list);
        margin: var(--s-4) auto 0;
        padding: 0 var(--s-2);
    }
    .about p,
    .about h2,
    .about h3 {
        max-width: var(--w-read);
    }
</style>
