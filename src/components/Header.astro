---
import ChaosStar from "@/components/ChaosStar.astro"
import ThemeToggle from "@/components/ThemeToggle.astro"
import { TYPES, TYPE_LABELS, pluralOf } from "@/lib/taxonomy.js"

const curated = [
    { href: "/essays/", label: "Essays" },
    { href: "/blogs/", label: "Blogs" },
    { href: "/podcasts/", label: "Podcasts" },
    { href: "/tools/", label: "Tools" },
    { href: "/all/", label: "All" },
    { href: "/about/", label: "About" }
]

const mobileNav = [
    ...TYPES.map((t) => ({ href: `/${pluralOf(t)}/`, label: TYPE_LABELS[t] })),
    { href: "/all/", label: "All" },
    { href: "/about/", label: "About" }
]
---
<header class="site-header">
    <a class="brand" href="/" aria-label="Chaos Current home">
        <ChaosStar size={22} />
        <span class="brand-name">Chaos Current</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
        {curated.map((item) => (
            <a href={item.href}>{item.label}</a>
        ))}
    </nav>

    <div class="header-controls">
        <a class="search-link" href="/all/#search" aria-label="Search directory">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <line x1="16" y1="16" x2="21" y2="21" />
            </svg>
        </a>
        <ThemeToggle />
        <button
            id="nav-toggle"
            class="hamburger"
            type="button"
            aria-controls="mobile-nav"
            aria-expanded="false"
            aria-label="Open navigation"
        >
            <svg class="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <line x1="4" y1="7" x2="20" y2="7" />
                <line x1="4" y1="12" x2="20" y2="12" />
                <line x1="4" y1="17" x2="20" y2="17" />
            </svg>
            <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <line x1="6" y1="6" x2="18" y2="18" />
                <line x1="18" y1="6" x2="6" y2="18" />
            </svg>
        </button>
    </div>
</header>

<div id="mobile-nav" class="mobile-nav" hidden>
    <nav aria-label="All sections">
        <ul>
            {mobileNav.map((item) => (
                <li><a href={item.href}>{item.label}</a></li>
            ))}
        </ul>
    </nav>
</div>

<style>
    .site-header {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        padding: var(--s-2) clamp(var(--s-2), 4vw, var(--s-4));
        border-bottom: 1px solid var(--rule);
        position: sticky;
        top: 0;
        background: color-mix(in srgb, var(--bg) 92%, transparent);
        backdrop-filter: blur(8px);
        z-index: 20;
    }
    .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6ch;
        color: var(--ink-strong);
        font-weight: 500;
    }
    .brand-name {
        font-family: var(--font-ui);
        font-size: var(--fs-12);
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }
    .site-nav {
        display: flex;
        gap: var(--s-2);
        margin-left: auto;
    }
    .site-nav a {
        font-family: var(--font-ui);
        font-size: var(--fs-12);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ink-mute);
    }
    .site-nav a:hover { color: var(--accent-bright); }
    .header-controls {
        display: inline-flex;
        gap: var(--s-1);
        align-items: center;
        margin-left: auto;
    }
    .site-nav + .header-controls { margin-left: 0; }
    .search-link {
        color: var(--ink-mute);
        display: inline-flex;
        padding: 6px;
        border-radius: 4px;
    }
    .search-link:hover { color: var(--accent); }

    .hamburger {
        display: none;
        background: transparent;
        border: 0;
        color: var(--ink-mute);
        cursor: pointer;
        padding: 6px;
        border-radius: 4px;
        align-items: center;
    }
    .hamburger:hover { color: var(--accent); }
    .hamburger .icon-close { display: none; }
    .hamburger[aria-expanded="true"] .icon-open { display: none; }
    .hamburger[aria-expanded="true"] .icon-close { display: inline; }

    .mobile-nav {
        position: fixed;
        inset: 0;
        padding-top: 64px;
        background: color-mix(in srgb, var(--bg) 96%, transparent);
        backdrop-filter: blur(12px);
        z-index: 15;
        overflow-y: auto;
    }
    .mobile-nav nav { max-width: var(--w-list); margin: 0 auto; padding: var(--s-3); }
    .mobile-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
    }
    .mobile-nav li + li { border-top: 1px solid var(--rule); }
    .mobile-nav a {
        display: block;
        padding: var(--s-2) 0;
        font-family: var(--font-ui);
        font-size: var(--fs-18);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ink);
        font-weight: 400;
    }
    .mobile-nav a:hover,
    .mobile-nav a:focus-visible { color: var(--accent-bright); }

    @media (max-width: 720px) {
        .site-nav { display: none; }
        .hamburger { display: inline-flex; }
    }
</style>

<script>
    const toggle = document.getElementById("nav-toggle")
    const mobileNav = document.getElementById("mobile-nav")
    if (toggle && mobileNav) {
        const open = () => {
            mobileNav.hidden = false
            toggle.setAttribute("aria-expanded", "true")
            document.body.classList.add("nav-open")
            const firstLink = mobileNav.querySelector("a")
            if (firstLink) firstLink.focus()
        }
        const close = () => {
            mobileNav.hidden = true
            toggle.setAttribute("aria-expanded", "false")
            document.body.classList.remove("nav-open")
            toggle.focus()
        }
        toggle.addEventListener("click", () => {
            if (mobileNav.hidden) open()
            else close()
        })
        mobileNav.addEventListener("click", (e) => {
            if (e.target instanceof HTMLAnchorElement) close()
        })
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !mobileNav.hidden) close()
        })
        const mq = window.matchMedia("(max-width: 720px)")
        mq.addEventListener("change", (m) => {
            if (!m.matches && !mobileNav.hidden) close()
        })
    }
</script>
