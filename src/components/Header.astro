---
import ChaosStar from "@/components/ChaosStar.astro"
import ThemeToggle from "@/components/ThemeToggle.astro"

const curated = [
    { href: "/essays/", label: "Essays" },
    { href: "/blogs/", label: "Blogs" },
    { href: "/podcasts/", label: "Podcasts" },
    { href: "/tools/", label: "Tools" },
    { href: "/all/", label: "All" },
    { href: "/about/", label: "About" }
]
---
<header class="site-header">
    <a class="brand" href="/" aria-label="Chaos Current home">
        <ChaosStar size={22} />
        <span class="brand-name">Chaos Current</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
        {curated.map((item) => (
            <a href={item.href}>{item.label}</a>
        ))}
    </nav>

    <div class="header-controls">
        <a class="search-link" href="/all/#search" aria-label="Search directory">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <line x1="16" y1="16" x2="21" y2="21" />
            </svg>
        </a>
        <ThemeToggle />
    </div>
</header>

<style>
    .site-header {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        padding: var(--s-2) clamp(var(--s-2), 4vw, var(--s-4));
        border-bottom: 1px solid var(--rule);
        position: sticky;
        top: 0;
        background: color-mix(in srgb, var(--bg) 92%, transparent);
        backdrop-filter: blur(8px);
        z-index: 10;
    }
    .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6ch;
        color: var(--ink-strong);
        font-weight: 500;
    }
    .brand-name {
        font-family: var(--font-ui);
        font-size: var(--fs-12);
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }
    .site-nav {
        display: flex;
        gap: var(--s-2);
        margin-left: auto;
    }
    .site-nav a {
        font-family: var(--font-ui);
        font-size: var(--fs-12);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ink-mute);
    }
    .site-nav a:hover { color: var(--accent-bright); }
    .header-controls {
        display: inline-flex;
        gap: var(--s-1);
        align-items: center;
    }
    .search-link {
        color: var(--ink-mute);
        display: inline-flex;
        padding: 6px;
        border-radius: 4px;
    }
    .search-link:hover { color: var(--accent); }

    @media (max-width: 720px) {
        .site-nav { display: none; }
    }
</style>
