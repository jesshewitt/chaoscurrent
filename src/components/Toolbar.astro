---
import { TYPES, TYPE_LABELS } from "@/lib/taxonomy.js"
const { topics = [] } = Astro.props
---
<div class="toolbar" data-filter-root>
    <div class="search-field">
        <input
            id="filter-search"
            type="search"
            placeholder="Search titles, authors, topics..."
            autocomplete="off"
            aria-label="Search"
        />
        <button
            type="button"
            id="filter-toggle"
            class="filter-toggle"
            aria-label="Toggle filters"
            aria-expanded="false"
            aria-controls="filter-panel"
        >
            <svg class="filter-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
                <line x1="5" y1="6" x2="19" y2="6" />
                <line x1="8" y1="12" x2="16" y2="12" />
                <line x1="11" y1="18" x2="13" y2="18" />
            </svg>
            <span class="filter-badge" id="filter-badge"></span>
        </button>
        <div class="filter-panel" id="filter-panel" role="group" aria-label="Filters" hidden>
            <section class="filter-section">
                <p class="label">Format</p>
                <div class="filter-grid">
                    {TYPES.map((t) => (
                        <label class="filter-option">
                            <input type="checkbox" data-axis="type" data-value={t} />
                            <span>{TYPE_LABELS[t]}</span>
                        </label>
                    ))}
                </div>
            </section>
            <section class="filter-section">
                <p class="label">Topic</p>
                <div class="filter-grid">
                    {topics.map((topic) => (
                        <label class="filter-option">
                            <input type="checkbox" data-axis="topic" data-value={topic.slug} />
                            <span>{topic.label}</span>
                        </label>
                    ))}
                </div>
            </section>
            <div class="filter-actions">
                <button type="button" id="clear-filters" class="reset" hidden>Clear all</button>
            </div>
        </div>
    </div>

    <p id="result-count" class="result-count meta" aria-live="polite"></p>
</div>

<style>
    .toolbar {
        position: sticky;
        top: 64px;
        background: color-mix(in srgb, var(--bg) 92%, transparent);
        backdrop-filter: blur(8px);
        padding: var(--s-2) 0;
        border-bottom: 1px solid var(--rule);
        z-index: 10;
    }

    .search-field {
        position: relative;
    }
    #filter-search {
        width: 100%;
        padding: 10px 48px 10px 12px;
        background: var(--bg-elev);
        border: 1px solid var(--rule);
        color: var(--ink);
        border-radius: 4px;
        font-family: var(--font-body);
        font-size: var(--fs-16);
        box-sizing: border-box;
    }

    .filter-toggle {
        position: absolute;
        top: 50%;
        right: 6px;
        transform: translateY(-50%);
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: 0;
        color: var(--ink-mute);
        cursor: pointer;
        border-radius: 4px;
        padding: 0;
    }
    .filter-toggle:hover { color: var(--accent); }
    .filter-toggle[aria-expanded="true"] {
        color: var(--accent);
        background: color-mix(in srgb, var(--accent) 12%, transparent);
    }

    .filter-badge:empty { display: none; }
    .filter-badge:not(:empty) {
        position: absolute;
        top: 2px;
        right: 2px;
        min-width: 14px;
        height: 14px;
        padding: 0 4px;
        background: var(--gold);
        color: var(--bg);
        border-radius: 999px;
        font-family: var(--font-ui);
        font-size: 9px;
        line-height: 14px;
        text-align: center;
        letter-spacing: 0;
    }

    .filter-panel[hidden] { display: none; }
    .filter-panel {
        position: absolute;
        top: calc(100% + 6px);
        right: 0;
        width: min(32rem, calc(100vw - var(--s-4)));
        background: var(--bg-elev);
        border: 1px solid var(--rule);
        border-radius: 4px;
        padding: var(--s-2);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.35);
        z-index: 30;
    }
    .filter-section + .filter-section { margin-top: var(--s-2); }
    .filter-section .label { margin-bottom: var(--s-1); }
    .filter-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4ch;
    }
    .filter-option {
        position: relative;
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border: 1px solid var(--rule);
        border-radius: 999px;
        font-family: var(--font-ui);
        font-size: var(--fs-12);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-mute);
        cursor: pointer;
        user-select: none;
        transition: color 120ms ease-out, background 120ms ease-out, border-color 120ms ease-out;
    }
    .filter-option input {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
    .filter-option:hover { color: var(--ink); border-color: var(--ink-mute); }
    .filter-option:has(input:checked) {
        color: var(--bg);
        background: var(--gold);
        border-color: var(--gold);
    }
    .filter-option:has(input:focus-visible) {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
    }

    .filter-actions {
        margin-top: var(--s-2);
        padding-top: var(--s-2);
        border-top: 1px solid var(--rule);
        display: flex;
        justify-content: flex-end;
    }
    .reset {
        background: transparent;
        border: 0;
        color: var(--accent);
        font-family: var(--font-ui);
        font-size: var(--fs-12);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        padding: 4px 8px;
    }
    .reset:hover { color: var(--accent-bright); }
    .reset[hidden] { display: none; }

    .result-count {
        margin: var(--s-1) 0 0;
        min-height: 1.4em;
    }
</style>
