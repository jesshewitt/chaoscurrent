---
const year = new Date().getFullYear()
---
<footer class="site-footer">
    <div class="footer-inner">
        <p class="meta">&copy; {year} Chaos Current</p>
    </div>
</footer>

<style>
    .site-footer {
        margin-top: var(--s-6);
        padding: var(--s-4) clamp(var(--s-2), 4vw, var(--s-4));
        border-top: 1px solid var(--rule);
    }
    .footer-inner {
        max-width: var(--w-list);
        margin: 0 auto;
    }
    .footer-inner p { margin: 0; }
</style>
